# --- Helpers ---

def slugify(text):
    """Turn a title into a filename-safe slug."""
    text = text.lower().strip()
    text = re.sub(r"[^\w\s-]", "", text)
    text = re.sub(r"[\s_]+", "-", text)
    text = re.sub(r"-+", "-", text)
    return text.strip("-")[:80]


def find_entries(project=None, entry_type=None, status=None, scope=None, topics=None):
    """Find all journal entries, optionally filtered."""
    entries = []
    if project:
        search_dirs = [PROJECTS_DIR / project]
    else:
        search_dirs = [d for d in PROJECTS_DIR.iterdir() if d.is_dir()] if PROJECTS_DIR.exists() else []

    for proj_dir in search_dirs:
        if not proj_dir.exists():
            continue
        type_dirs = [entry_type] if entry_type else ENTRY_TYPES
        for t in type_dirs:
            t_dir = proj_dir / (t + "s")  # sessions/, decisions/, etc.
            if not t_dir.exists():
                continue
            for f in sorted(t_dir.glob("*.md")):
                text = f.read_text()
                meta, body = parse_frontmatter(text)
                if status and meta.get("status") != status:
                    continue
                if scope and meta.get("scope") != scope:
                    continue
                if topics:
                    entry_tags = meta.get("tags", [])
                    if isinstance(entry_tags, str):
                        entry_tags = [t.strip() for t in entry_tags.split(",")]
                    entry_tags_lower = {t.lower() for t in entry_tags}
                    if not any(t.lower() in entry_tags_lower for t in topics):
                        continue
                entries.append({
                    "path": f,
                    "meta": meta,
                    "body": body,
                    "project": proj_dir.name,
                })
    return entries

# --- ANSI colors (minimal) ---

def dim(s):    return f"\033[2m{s}\033[0m"
def bold(s):   return f"\033[1m{s}\033[0m"
def red(s):    return f"\033[31m{s}\033[0m"
def green(s):  return f"\033[32m{s}\033[0m"
def yellow(s): return f"\033[33m{s}\033[0m"
def cyan(s):   return f"\033[36m{s}\033[0m"

def magenta(s): return f"\033[35m{s}\033[0m"

TYPE_COLORS = {
    "session": cyan,
    "decision": green,
    "insight": yellow,
    "stuck": red,
    "note": magenta,
}

def no_color():
    """Check if color should be disabled."""
    return os.environ.get("NO_COLOR") or not sys.stdout.isatty()

def c(fn, s):
    """Apply color function, respecting NO_COLOR."""
    return s if no_color() else fn(s)

# --- Commands ---

def cmd_new(args):
    """Create a new journal entry."""
    entry_type = args.type
    project = args.project
    title = args.title or f"New {entry_type}"

    proj_dir = PROJECTS_DIR / project / (entry_type + "s")
    proj_dir.mkdir(parents=True, exist_ok=True)

    date_prefix = datetime.now().strftime("%Y-%m-%d")
    slug = slugify(title)
    filename = f"{date_prefix}-{slug}.md" if slug else f"{date_prefix}.md"
    filepath = proj_dir / filename

    # Avoid collisions
    counter = 2
    while filepath.exists():
        filepath = proj_dir / f"{date_prefix}-{slug}-{counter}.md"
        counter += 1

    scope = args.scope or "private"

    summary = args.summary or ""

    meta = {
        "type": entry_type,
        "title": title,
        "project": project,
        "created": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
        "summary": summary,
        "tags": [],
        "scope": scope,
        "status": "open" if entry_type == "stuck" else "active",
    }

    content = format_frontmatter(meta) + "\n\n" + TEMPLATES[entry_type]
    filepath.write_text(content)

    # Also create overview.md if it doesn't exist
    overview = PROJECTS_DIR / project / "overview.md"
    if not overview.exists():
        overview.write_text(f"# {project}\n\nProject overview - auto-generated.\n")

    print(f"Created: {filepath}")

    # Open in editor if interactive
    editor = os.environ.get("EDITOR")
    if editor and sys.stdin.isatty():
        os.execvp(editor, [editor, str(filepath)])


def cmd_list(args):
    """List journal entries."""
    entries = find_entries(project=args.project, entry_type=args.type)

    if not entries:
        print("No entries found.")
        return

    # Group by project
    by_project = {}
    for e in entries:
        by_project.setdefault(e["project"], []).append(e)

    for proj, proj_entries in sorted(by_project.items()):
        print(c(bold, f"\n  {proj}"))
        print(c(dim, "  " + "─" * 40))
        for e in proj_entries:
            meta = e["meta"]
            t = meta.get("type", "?")
            title = meta.get("title", e["path"].stem)
            status = meta.get("status", "")
            color_fn = TYPE_COLORS.get(t, dim)
            status_str = f" [{status}]" if status else ""
            padded_t = f"{t:>10}"
            print(f"  {c(color_fn, padded_t)}  {title}{c(dim, status_str)}")
            print(f"  {c(dim, str(e['path']))}")
    print()


def cmd_show(args):
    """Show a journal entry."""
    path = Path(args.path)
    if not path.exists():
        # Try to find it as a partial match
        matches = list(PROJECTS_DIR.rglob(f"*{args.path}*"))
        if len(matches) == 1:
            path = matches[0]
        elif len(matches) > 1:
            print("Multiple matches:")
            for m in matches:
                print(f"  {m}")
            return
        else:
            print(f"Not found: {args.path}")
            return

    text = path.read_text()
    meta, body = parse_frontmatter(text)

    t = meta.get("type", "?")
    color_fn = TYPE_COLORS.get(t, dim)

    print()
    print(c(bold, f"  {meta.get('title', path.stem)}"))
    print(f"  {c(color_fn, t)} | {c(dim, meta.get('created', '?'))} | status: {meta.get('status', '?')}")
    tags = meta.get("tags", [])
    if tags:
        tag_str = ", ".join(tags) if isinstance(tags, list) else str(tags)
        print(f"  tags: {c(dim, tag_str)}")
    print(c(dim, "  " + "─" * 50))
    print()
    print(body)
    print()


def cmd_search(args):
    """Search entries by text."""
    query = args.query.lower()
    entries = find_entries()
    hits = []

    for e in entries:
        text = e["path"].read_text().lower()
        if query in text:
            hits.append(e)

    if not hits:
        print(f"No entries matching '{args.query}'.")
        return

    print(f"\n  Found {len(hits)} match(es) for '{args.query}':\n")
    for e in hits:
        meta = e["meta"]
        t = meta.get("type", "?")
        title = meta.get("title", e["path"].stem)
        color_fn = TYPE_COLORS.get(t, dim)
        padded_t = f"{t:>10}"
        proj_name = e["project"]
        print(f"  {c(color_fn, padded_t)}  {title} {c(dim, f'({proj_name})')}")

        # Show matching lines for context
        text = e["path"].read_text()
        for i, line in enumerate(text.splitlines()):
            if query in line.lower() and not line.startswith("---"):
                snippet = line.strip()[:100]
                print(f"             {c(dim, snippet)}")
        print()


def cmd_status(args):
    """Show project status - open stuck points, recent sessions."""
    project = args.project

    if project:
        projects = [project]
    else:
        if not PROJECTS_DIR.exists():
            print("No projects found. Create one with: journal new <type> <project>")
            return
        projects = sorted([d.name for d in PROJECTS_DIR.iterdir() if d.is_dir()])

    if not projects:
        print("No projects found.")
        return

    for proj in projects:
        print(c(bold, f"\n  {proj}"))
        print(c(dim, "  " + "═" * 40))

        # Open stuck points
        stuck = find_entries(project=proj, entry_type="stuck", status="open")
        if stuck:
            print(c(red, f"\n  Stuck ({len(stuck)}):"))
            for e in stuck:
                print(f"    - {e['meta'].get('title', '?')}")
                summary = e["meta"].get("summary", "")
                if summary:
                    print(f"      {c(dim, summary)}")
        else:
            print(c(green, "\n  No open stuck points"))

        # Recent sessions (last 3)
        sessions = find_entries(project=proj, entry_type="session")
        if sessions:
            recent = sessions[-3:]
            print(f"\n  {c(cyan, f'Recent sessions ({len(sessions)} total):')}")
            for e in recent:
                date = e["meta"].get("created", "?")[:10]
                title = e["meta"].get("title", "?")
                summary = e["meta"].get("summary", "")
                print(f"    {c(dim, date)}  {title}")
                if summary:
                    print(f"              {c(dim, summary)}")

        # Active decisions
        decisions = find_entries(project=proj, entry_type="decision")
        if decisions:
            print(f"\n  {c(green, f'Decisions ({len(decisions)}):')}")
            for e in decisions[-3:]:
                print(f"    - {e['meta'].get('title', '?')}")
                summary = e["meta"].get("summary", "")
                if summary:
                    print(f"      {c(dim, summary)}")

        # Recent insights (last 3)
        insights = find_entries(project=proj, entry_type="insight")
        if insights:
            print(f"\n  {c(yellow, f'Insights ({len(insights)}):')}")
            for e in insights[-3:]:
                print(f"    - {e['meta'].get('title', '?')}")
                summary = e["meta"].get("summary", "")
                if summary:
                    print(f"      {c(dim, summary)}")

    print()


def cmd_projects(args):
    """List all projects."""
    if not PROJECTS_DIR.exists():
        print("No projects yet. Create one with: journal new <type> <project>")
        return

    projects = sorted([d for d in PROJECTS_DIR.iterdir() if d.is_dir()])
    if not projects:
        print("No projects yet.")
        return

    print(c(bold, "\n  Projects:\n"))
    for proj_dir in projects:
        name = proj_dir.name
        # Count entries
        counts = {}
        for t in ENTRY_TYPES:
            t_dir = proj_dir / (t + "s")
            if t_dir.exists():
                counts[t] = len(list(t_dir.glob("*.md")))

        stuck_open = len(find_entries(project=name, entry_type="stuck", status="open"))

        parts = []
        for t in ENTRY_TYPES:
            if counts.get(t, 0) > 0:
                color_fn = TYPE_COLORS.get(t, dim)
                label = f"{counts[t]} {t}"
                if t == "stuck" and stuck_open > 0:
                    label += f" ({stuck_open} open)"
                parts.append(c(color_fn, label))

        summary = " | ".join(parts) if parts else c(dim, "empty")
        print(f"  {c(bold, name)}")
        print(f"    {summary}")
    print()


def cmd_resolve(args):
    """Mark a stuck entry as resolved."""
    path = Path(args.path)
    if not path.exists():
        matches = list(PROJECTS_DIR.rglob(f"*{args.path}*"))
        matches = [m for m in matches if "/stucks/" in str(m)]
        if len(matches) == 1:
            path = matches[0]
        elif len(matches) > 1:
            print("Multiple matches:")
            for m in matches:
                print(f"  {m}")
            return
        else:
            print(f"Not found: {args.path}")
            return

    text = path.read_text()
    meta, body = parse_frontmatter(text)

    if args.solution:
        body += f"\n\n## Resolution\n\n{args.solution}\n"

    meta["status"] = "resolved"
    meta["resolved"] = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")

    path.write_text(format_frontmatter(meta) + "\n\n" + body)
    print(f"Resolved: {meta.get('title', path.stem)}")
    print(f"  {path}")


def cmd_import(args):
    """Import a file into the journal with context."""
    import shutil

    source = Path(args.file).expanduser().resolve()
    if not source.exists():
        print(f"File not found: {source}")
        return

    project = args.project
    title = args.title or source.name
    summary = args.summary or ""
    scope = args.scope or "private"

    # Create attachments directory
    attach_dir = PROJECTS_DIR / project / "attachments"
    attach_dir.mkdir(parents=True, exist_ok=True)

    # Copy file
    dest_file = attach_dir / source.name
    counter = 2
    while dest_file.exists():
        stem = source.stem
        suffix = source.suffix
        dest_file = attach_dir / f"{stem}-{counter}{suffix}"
        counter += 1
    shutil.copy2(source, dest_file)

    # Create a note entry referencing the file
    notes_dir = PROJECTS_DIR / project / "notes"
    notes_dir.mkdir(parents=True, exist_ok=True)

    date_prefix = datetime.now().strftime("%Y-%m-%d")
    slug = slugify(title)
    filename = f"{date_prefix}-{slug}.md" if slug else f"{date_prefix}.md"
    entry_path = notes_dir / filename

    rel_attachment = os.path.relpath(dest_file, entry_path.parent)

    meta = {
        "type": "note",
        "title": title,
        "project": project,
        "created": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
        "summary": summary,
        "tags": args.tags.split(",") if args.tags else [],
        "scope": scope,
        "status": "active",
        "attachment": str(dest_file.relative_to(PROJECTS_DIR / project)),
    }

    context = args.context or ""
    body = f"Imported from `{source}`\n"
    if context:
        body += f"\n{context}\n"
    body += f"\n## Attachment\n\n[{source.name}]({rel_attachment})\n"

    entry_path.write_text(format_frontmatter(meta) + "\n\n" + body)

    # Also create overview.md if it doesn't exist
    overview = PROJECTS_DIR / project / "overview.md"
    if not overview.exists():
        overview.write_text(f"# {project}\n\nProject overview - auto-generated.\n")

    print(f"  {c(green, 'Imported')}: {source.name}")
    print(f"  Entry: {entry_path}")
    print(f"  Attachment: {dest_file}")


def cmd_index(args):
    """Build or rebuild the topic index from entry tags."""
    entries = find_entries()

    if not entries:
        print("No entries to index.")
        return

    # Build topic -> entries mapping
    topic_map = {}
    for e in entries:
        tags = e["meta"].get("tags", [])
        if isinstance(tags, str):
            tags = [t.strip() for t in tags.split(",") if t.strip()]
        for tag in tags:
            tag_lower = tag.lower()
            topic_map.setdefault(tag_lower, []).append(e)

    if not topic_map:
        print("No tags found in any entries. Add tags to entry frontmatter to build the index.")
        return

    # Build the index markdown
    lines = [
        "# Index",
        "",
        f"*Auto-generated on {datetime.now().strftime('%Y-%m-%d %H:%M')} "
        f"— {len(topic_map)} topics across {len(entries)} entries.*",
        "",
        "---",
        "",
    ]

    # Alphabetical letter headings
    sorted_topics = sorted(topic_map.keys())
    current_letter = None

    for topic in sorted_topics:
        first = topic[0].upper()
        if first != current_letter:
            current_letter = first
            lines.append(f"## {current_letter}")
            lines.append("")

        topic_entries = topic_map[topic]
        lines.append(f"### {topic}")
        lines.append("")
        for e in sorted(topic_entries, key=lambda x: x["meta"].get("created", "")):
            meta = e["meta"]
            title = meta.get("title", e["path"].stem)
            entry_type = meta.get("type", "?")
            project = e["project"]
            status = meta.get("status", "")
            date = meta.get("created", "")[:10]

            # Relative link from data/ root
            rel_path = e["path"].relative_to(DATA_DIR)

            status_badge = ""
            if entry_type == "stuck":
                status_badge = " `OPEN`" if status == "open" else " `resolved`"

            summary = meta.get("summary", "")
            lines.append(
                f"- [{title}]({rel_path}) "
                f"— *{entry_type}* in **{project}**{status_badge} "
                f"({date})"
            )
            if summary:
                lines.append(f"  > {summary}")
        lines.append("")

    # Write index file
    index_path = DATA_DIR / "INDEX.md"
    index_path.write_text("\n".join(lines) + "\n")

    print(f"  {c(green, 'Index rebuilt')}: {len(topic_map)} topics, {len(entries)} entries")
    print(f"  {c(dim, str(index_path))}")


def entry_id(entry):
    """Short ID for an entry: project/type/filename-stem."""
    return f"{entry['project']}/{entry['meta'].get('type', '?')}/{entry['path'].stem}"


def entry_short_id(entry):
    """Even shorter: just the filename stem."""
    return entry["path"].stem


def resolve_related(entries):
    """Build a map of entry -> [related entries] from the 'related' frontmatter field.

    The 'related' field contains partial filename matches, resolved against all entries.
    """
    # Build a lookup: stem -> entry
    by_stem = {}
    for e in entries:
        by_stem[e["path"].stem] = e

    relations = {}
    for e in entries:
        related_refs = e["meta"].get("related", [])
        if isinstance(related_refs, str):
            related_refs = [r.strip() for r in related_refs.split(",") if r.strip()]
        resolved = []
        for ref in related_refs:
            # Try exact stem match first
            if ref in by_stem:
                resolved.append(by_stem[ref])
                continue
            # Try partial match
            for stem, candidate in by_stem.items():
                if ref in stem:
                    resolved.append(candidate)
                    break
        relations[e["path"].stem] = resolved

    return relations


def cmd_graph(args):
    """Generate a knowledge graph as a mermaid diagram."""
    entries = find_entries()
    if not entries:
        print("No entries to graph.")
        return

    relations = resolve_related(entries)

    # Build tag co-occurrence edges (entries sharing tags are connected)
    tag_entries = {}
    for e in entries:
        tags = e["meta"].get("tags", [])
        if isinstance(tags, str):
            tags = [t.strip() for t in tags.split(",") if t.strip()]
        for tag in tags:
            tag_entries.setdefault(tag.lower(), []).append(e)

    # Node styling by type
    type_shapes = {
        "stuck": ("{{", "}}"),     # diamond-ish
        "decision": ("[[", "]]"),  # subroutine
        "insight": ("(", ")"),     # rounded
        "session": ("[", "]"),     # rectangle
        "note": ("([", "])"),      # stadium
    }

    lines = ["graph LR"]

    # Define nodes
    node_ids = {}
    for i, e in enumerate(entries):
        nid = f"e{i}"
        node_ids[e["path"].stem] = nid
        meta = e["meta"]
        title = meta.get("title", e["path"].stem)
        # Truncate long titles
        if len(title) > 40:
            title = title[:37] + "..."
        # Escape quotes for mermaid
        title = title.replace('"', "'")
        t = meta.get("type", "note")
        l, r = type_shapes.get(t, ("[", "]"))
        lines.append(f"    {nid}{l}\"{title}\"{r}")

    lines.append("")

    # Explicit related edges
    explicit_edges = set()
    for e in entries:
        stem = e["path"].stem
        nid = node_ids.get(stem)
        if not nid:
            continue
        for rel in relations.get(stem, []):
            rel_nid = node_ids.get(rel["path"].stem)
            if rel_nid and nid != rel_nid:
                edge = tuple(sorted([nid, rel_nid]))
                if edge not in explicit_edges:
                    explicit_edges.add(edge)
                    lines.append(f"    {nid} --- {rel_nid}")

    # Tag-based edges (entries sharing a tag)
    tag_edges = set()
    for tag, tag_ents in tag_entries.items():
        if len(tag_ents) < 2:
            continue
        for i in range(len(tag_ents)):
            for j in range(i + 1, len(tag_ents)):
                a = node_ids.get(tag_ents[i]["path"].stem)
                b = node_ids.get(tag_ents[j]["path"].stem)
                if a and b and a != b:
                    edge = tuple(sorted([a, b]))
                    if edge not in explicit_edges and edge not in tag_edges:
                        tag_edges.add(edge)
                        lines.append(f"    {a} -.- {b}")

    # Write GRAPH.md
    graph_content = [
        "# Knowledge Graph",
        "",
        f"*Auto-generated on {datetime.now().strftime('%Y-%m-%d %H:%M')} "
        f"— {len(entries)} entries, "
        f"{len(explicit_edges)} direct links, "
        f"{len(tag_edges)} shared-tag connections.*",
        "",
        "Solid lines = explicit `related` links. Dotted lines = shared tags.",
        "",
        "```mermaid",
    ]
    graph_content.extend(lines)
    graph_content.append("```")
    graph_content.append("")

    # Legend
    graph_content.extend([
        "## Legend",
        "",
        "| Shape | Type |",
        "|-------|------|",
        "| `{{ }}` | stuck |",
        "| `[[ ]]` | decision |",
        "| `( )` | insight |",
        "| `[ ]` | session |",
        "| `([ ])` | note |",
        "",
    ])

    graph_path = DATA_DIR / "GRAPH.md"
    graph_path.write_text("\n".join(graph_content) + "\n")

    print(f"  {c(green, 'Graph built')}: {len(entries)} entries, "
          f"{len(explicit_edges)} direct + {len(tag_edges)} tag edges")
    print(f"  {c(dim, str(graph_path))}")


# Sections that contain conclusions worth preserving during scrub
KEEPER_SECTIONS = {"## Resolution", "## The decision", "## Why this approach", "## The insight", "## Takeaway"}


def scrub_body(body):
    """Strip a body down to only conclusion sections.

    Returns the preserved text (may be empty).
    """
    kept = []
    current_section = None
    current_lines = []

    for line in body.splitlines():
        if line.startswith("## "):
            # Save previous section if it was a keeper
            if current_section and current_lines:
                kept.append(current_section)
                kept.extend(current_lines)
                kept.append("")
            # Check if new section is a keeper
            if any(line.startswith(k) for k in KEEPER_SECTIONS):
                current_section = line
                current_lines = []
            else:
                current_section = None
                current_lines = []
        elif current_section is not None:
            current_lines.append(line)

    # Don't forget the last section
    if current_section and current_lines:
        kept.append(current_section)
        kept.extend(current_lines)

    return "\n".join(kept).strip()


def cmd_scrub(args):
    """Scrub all entries matching a scope, preserving conclusions as tombstones."""
    scope = args.scope
    no_tombstones = args.no_tombstones
    dry_run = args.dry_run

    entries = find_entries()
    targets = [e for e in entries if e["meta"].get("scope") == scope]

    if not targets:
        print(f"No entries with scope '{scope}' found.")
        return

    print(f"\n  Found {c(bold, str(len(targets)))} entries with scope {c(red, scope)}:\n")
    for e in targets:
        meta = e["meta"]
        title = meta.get("title", e["path"].stem)
        t = meta.get("type", "?")
        color_fn = TYPE_COLORS.get(t, dim)
        padded_t = f"{t:>10}"
        proj_name = e["project"]
        print(f"  {c(color_fn, padded_t)}  {title} {c(dim, f'({proj_name})')}")

    if dry_run:
        print(f"\n  {c(dim, 'Dry run - no changes made.')}")
        return

    # Confirm
    if sys.stdin.isatty():
        print()
        answer = input(f"  Scrub these {len(targets)} entries? [y/N] ")
        if answer.lower() != "y":
            print("  Aborted.")
            return

    scrubbed = 0
    deleted = 0
    for e in targets:
        meta = e["meta"]
        body = e["body"]
        path = e["path"]

        if no_tombstones:
            path.unlink()
            deleted += 1
            continue

        # Preserve conclusions
        preserved = scrub_body(body)

        # Build tombstone
        meta["title"] = "[scrubbed]"
        meta["scrubbed"] = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
        meta["original_scope"] = scope
        meta.pop("scope", None)

        tombstone_body = "*Details scrubbed. "
        if preserved:
            tombstone_body += "Conclusion preserved.*\n\n" + preserved
        else:
            tombstone_body += "No conclusions to preserve.*"

        path.write_text(format_frontmatter(meta) + "\n\n" + tombstone_body + "\n")
        scrubbed += 1

    if no_tombstones:
        print(f"\n  {c(red, f'Deleted {deleted} entries')} (no tombstones).")
    else:
        print(f"\n  {c(green, f'Scrubbed {scrubbed} entries')} — tombstones preserved.")

    # Rebuild index
    cmd_index(args)


def filter_entries(args):
    """Get entries matching the filter flags on args."""
    scope = getattr(args, "scope", None)
    topics = getattr(args, "topic", None)
    project = getattr(args, "project", None)
    return find_entries(project=project, scope=scope, topics=topics)


def copy_entries_to(entries, dest_dir):
    """Copy entries into a new journal directory, preserving structure."""
    dest_projects = dest_dir / "projects"
    copied = 0
    for e in entries:
        # Mirror the path structure: projects/<project>/<type>s/<file>
        rel = e["path"].relative_to(PROJECTS_DIR).parent  # e.g. tapedeck/stucks
        target_dir = dest_projects / rel
        target_dir.mkdir(parents=True, exist_ok=True)
        target = target_dir / e["path"].name

        import shutil
        shutil.copy2(e["path"], target)
        copied += 1

        # Also copy overview.md if it exists
        overview = PROJECTS_DIR / e["project"] / "overview.md"
        overview_target = dest_projects / e["project"] / "overview.md"
        if overview.exists() and not overview_target.exists():
            overview_target.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(overview, overview_target)

    return copied


def build_index_for(dest_dir):
    """Build an index for a journal at an arbitrary path."""
    # Temporarily swap DATA_DIR to build index in the target
    global DATA_DIR, PROJECTS_DIR
    orig_data, orig_proj = DATA_DIR, PROJECTS_DIR
    DATA_DIR = dest_dir
    PROJECTS_DIR = dest_dir / "projects"
    try:
        # Use a dummy args object
        class _Args:
            pass
        cmd_index(_Args())
    finally:
        DATA_DIR = orig_data
        PROJECTS_DIR = orig_proj


def cmd_export(args):
    """Export matching entries to a new journal."""
    dest = Path(args.to).expanduser().resolve()
    entries = filter_entries(args)

    if not entries:
        print("No entries match the given filters.")
        return

    # Show what will be exported
    label = []
    if args.scope:
        label.append(f"scope={args.scope}")
    if args.topic:
        label.append(f"topics={','.join(args.topic)}")
    if args.project:
        label.append(f"project={args.project}")
    filter_str = ", ".join(label) or "all"

    print(f"\n  Exporting {c(bold, str(len(entries)))} entries ({filter_str}) to:")
    print(f"  {c(cyan, str(dest))}\n")

    for e in entries:
        meta = e["meta"]
        t = meta.get("type", "?")
        title = meta.get("title", e["path"].stem)
        color_fn = TYPE_COLORS.get(t, dim)
        padded_t = f"{t:>10}"
        proj_name = e["project"]
        print(f"  {c(color_fn, padded_t)}  {title} {c(dim, f'({proj_name})')}")

    dest.mkdir(parents=True, exist_ok=True)
    copied = copy_entries_to(entries, dest)
    build_index_for(dest)

    print(f"\n  {c(green, f'Exported {copied} entries')}. Index built at {dest / 'INDEX.md'}")


def cmd_extract(args):
    """Extract matching entries to a new journal, scrubbing originals."""
    dest = Path(args.to).expanduser().resolve()
    entries = filter_entries(args)

    if not entries:
        print("No entries match the given filters.")
        return

    label = []
    if args.scope:
        label.append(f"scope={args.scope}")
    if args.topic:
        label.append(f"topics={','.join(args.topic)}")
    if args.project:
        label.append(f"project={args.project}")
    filter_str = ", ".join(label) or "all"

    print(f"\n  Extracting {c(bold, str(len(entries)))} entries ({filter_str})")
    print(f"  To: {c(cyan, str(dest))}")
    print(f"  Originals will be {c(red, 'scrubbed')} (tombstones preserved)\n")

    for e in entries:
        meta = e["meta"]
        t = meta.get("type", "?")
        title = meta.get("title", e["path"].stem)
        color_fn = TYPE_COLORS.get(t, dim)
        padded_t = f"{t:>10}"
        proj_name = e["project"]
        print(f"  {c(color_fn, padded_t)}  {title} {c(dim, f'({proj_name})')}")

    # Confirm
    if sys.stdin.isatty():
        print()
        answer = input(f"  Extract and scrub {len(entries)} entries? [y/N] ")
        if answer.lower() != "y":
            print("  Aborted.")
            return

    # 1. Copy to destination
    dest.mkdir(parents=True, exist_ok=True)
    copied = copy_entries_to(entries, dest)
    build_index_for(dest)

    # 2. Scrub originals (with tombstones)
    scrubbed = 0
    for e in entries:
        meta = e["meta"]
        body = e["body"]
        path = e["path"]
        preserved = scrub_body(body)

        meta["title"] = "[scrubbed]"
        meta["scrubbed"] = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
        original_scope = meta.get("scope", "")
        if original_scope:
            meta["original_scope"] = original_scope
            meta.pop("scope", None)

        tombstone_body = "*Details scrubbed. "
        if preserved:
            tombstone_body += "Conclusion preserved.*\n\n" + preserved
        else:
            tombstone_body += "No conclusions to preserve.*"

        path.write_text(format_frontmatter(meta) + "\n\n" + tombstone_body + "\n")
        scrubbed += 1

    # 3. Rebuild source index
    class _Args:
        pass
    cmd_index(_Args())

    print(f"\n  {c(green, f'Exported {copied} entries')} to {dest}")
    print(f"  {c(yellow, f'Scrubbed {scrubbed} originals')} (tombstones preserved)")


def cmd_sync(args):
    """Commit and push journal data to the private repo."""
    if not (DATA_DIR / ".git").exists():
        print(f"No git repo in {DATA_DIR}. Initialize one first:")
        print(f"  cd {DATA_DIR} && git init && gh repo create ai-journal-data --private --source=. --push")
        return

    def run(cmd):
        return subprocess.run(cmd, cwd=DATA_DIR, capture_output=True, text=True)

    # Check for changes before index rebuild
    result = run(["git", "status", "--porcelain"])
    if not result.stdout.strip():
        print(c(dim, "  Nothing to sync - journal is up to date."))
        return

    # Rebuild index and graph before committing
    cmd_index(args)
    cmd_graph(args)

    # Stage everything (including freshly rebuilt index)
    run(["git", "add", "-A"])

    # Build a commit message from what changed
    diff = run(["git", "diff", "--cached", "--name-only"])
    changed_files = [line.strip() for line in diff.stdout.splitlines() if line.strip()]

    # Summarize: count new/modified entries by type (skip INDEX.md, overview.md)
    summary_parts = []
    for f in changed_files:
        for t in ENTRY_TYPES:
            if f"/{t}s/" in f:
                summary_parts.append(t)
                break

    from collections import Counter
    if summary_parts:
        counts = Counter(summary_parts)
        msg = "journal: " + ", ".join(f"{v} {k}{'s' if v > 1 else ''}" for k, v in counts.items())
    else:
        msg = "journal: update index"

    if args.message:
        msg = args.message

    result = run(["git", "commit", "-m", msg])
    if result.returncode != 0:
        print(f"Commit failed: {result.stderr}")
        return

    print(f"  {c(green, 'Committed')}: {msg}")

    # Push
    result = run(["git", "push"])
    if result.returncode != 0:
        print(f"  Push failed: {result.stderr}")
        return

    print(f"  {c(green, 'Pushed')} to remote.")


# --- Main ---

def main():
    parser = argparse.ArgumentParser(
        prog="journal",
        description="ai-journal: shared memory between two minds",
    )
    sub = parser.add_subparsers(dest="command")

    # new
    p_new = sub.add_parser("new", help="Create a new entry")
    p_new.add_argument("type", choices=ENTRY_TYPES)
    p_new.add_argument("project", help="Project name")
    p_new.add_argument("-t", "--title", help="Entry title")
    p_new.add_argument("--summary", help="1-2 sentence summary for quick scanning")
    p_new.add_argument("-s", "--scope", help="Scope (default: private)", default="private")
    p_new.set_defaults(func=cmd_new)

    # list
    p_list = sub.add_parser("list", aliases=["ls"], help="List entries")
    p_list.add_argument("project", nargs="?", help="Filter by project")
    p_list.add_argument("--type", choices=ENTRY_TYPES, help="Filter by type")
    p_list.set_defaults(func=cmd_list)

    # show
    p_show = sub.add_parser("show", help="Show an entry")
    p_show.add_argument("path", help="File path or partial name")
    p_show.set_defaults(func=cmd_show)

    # search
    p_search = sub.add_parser("search", help="Search entries")
    p_search.add_argument("query", help="Text to search for")
    p_search.set_defaults(func=cmd_search)

    # status
    p_status = sub.add_parser("status", help="Show project status")
    p_status.add_argument("project", nargs="?", help="Project name")
    p_status.set_defaults(func=cmd_status)

    # projects
    sub.add_parser("projects", help="List all projects").set_defaults(func=cmd_projects)

    # resolve
    p_resolve = sub.add_parser("resolve", help="Mark a stuck entry as resolved")
    p_resolve.add_argument("path", help="Stuck entry path or partial name")
    p_resolve.add_argument("-s", "--solution", help="How it was resolved")
    p_resolve.set_defaults(func=cmd_resolve)

    # import
    p_import = sub.add_parser("import", help="Import a file into the journal")
    p_import.add_argument("file", help="File to import")
    p_import.add_argument("project", help="Project name")
    p_import.add_argument("-t", "--title", help="Entry title (default: filename)")
    p_import.add_argument("--summary", help="What this file is and why it matters")
    p_import.add_argument("--tags", help="Comma-separated tags")
    p_import.add_argument("--context", help="Additional context about the file")
    p_import.add_argument("-s", "--scope", help="Scope (default: private)", default="private")
    p_import.set_defaults(func=cmd_import)

    # scrub
    p_scrub = sub.add_parser("scrub", help="Scrub entries by scope, preserving conclusions")
    p_scrub.add_argument("scope", help="Scope to scrub (e.g. grafana-internal, personal)")
    p_scrub.add_argument("--no-tombstones", action="store_true", help="Delete entirely instead of leaving tombstones")
    p_scrub.add_argument("--dry-run", action="store_true", help="Show what would be scrubbed without doing it")
    p_scrub.set_defaults(func=cmd_scrub)

    # export
    p_export = sub.add_parser("export", help="Export matching entries to a new journal")
    p_export.add_argument("--to", required=True, help="Destination directory")
    p_export.add_argument("--scope", help="Filter by scope")
    p_export.add_argument("--topic", action="append", help="Filter by topic/tag (can repeat)")
    p_export.add_argument("--project", help="Filter by project")
    p_export.set_defaults(func=cmd_export)

    # extract
    p_extract = sub.add_parser("extract", help="Extract entries to new journal, scrub originals")
    p_extract.add_argument("--to", required=True, help="Destination directory")
    p_extract.add_argument("--scope", help="Filter by scope")
    p_extract.add_argument("--topic", action="append", help="Filter by topic/tag (can repeat)")
    p_extract.add_argument("--project", help="Filter by project")
    p_extract.set_defaults(func=cmd_extract)

    # index
    sub.add_parser("index", help="Rebuild the topic index from tags").set_defaults(func=cmd_index)

    # graph
    sub.add_parser("graph", help="Generate knowledge graph (mermaid)").set_defaults(func=cmd_graph)

    # sync
    p_sync = sub.add_parser("sync", help="Commit and push journal data")
    p_sync.add_argument("-m", "--message", help="Custom commit message")
    p_sync.set_defaults(func=cmd_sync)

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    # Ensure data dir exists
    PROJECTS_DIR.mkdir(parents=True, exist_ok=True)

    args.func(args)


if __name__ == "__main__":
    main()
